# ============================================================
# Remote Rocket — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Hunter.io — email discovery and verification for follow-up emails.
# Free tier: 25 searches + 50 verifications/month. https://hunter.io/api-keys
HUNTER_API_KEY=your-hunter-key-here

# --- Scraper Settings ---
# How often to run the full scrape cycle (in hours)
SCRAPE_INTERVAL_HOURS=12

# Jobs not seen in this many days will be marked inactive
# (Applied jobs are never auto-expired)
JOB_EXPIRY_DAYS=45

# --- UI Settings ---
# Minimum salary to show by default in the Browse Jobs filter
SALARY_MIN_DEFAULT=100000

# --- Claude Model ---
# Model used for job extraction. Haiku is fast and cheap (~$0.001/job).
# Switch to claude-sonnet-4-6 for higher quality extraction if needed.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Model used for Phase 2 resume tailoring (the document you send to employers).
# Sonnet is the default here — quality matters more than cost.
RESUME_MODEL=claude-sonnet-4-6

# Model for the one-time structuring pass when you upload your master resume.
# This is a lightweight parsing task, so cheap Haiku is the default.
STRUCTURE_MODEL=claude-haiku-4-5-20251001

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
# Use DEBUG during initial setup to see per-job details and token counts
LOG_LEVEL=INFO
