# ============================================================
# Remote Rocket — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Scraper Settings ---
# How often to run the full scrape cycle (in hours)
SCRAPE_INTERVAL_HOURS=12

# Jobs not seen in this many days will be marked inactive
# (Applied jobs are never auto-expired)
JOB_EXPIRY_DAYS=45

# --- UI Settings ---
# Minimum salary to show by default in the Browse Jobs filter
SALARY_MIN_DEFAULT=100000

# --- Claude Model ---
# Model used for job extraction. Haiku is fast and cheap (~$0.001/job).
# Switch to claude-sonnet-4-6 for higher quality extraction if needed.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
# Use DEBUG during initial setup to see per-job details and token counts
LOG_LEVEL=INFO
